{
  "name": "sage",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "npm run test:js && npm run test:php",
    "test:js": "jest",
    "test:js:watch": "jest --watch",
    "test:js:coverage": "jest --coverage",
    "test:php": "composer test",
    "lint:js": "eslint 'resources/js/**/*.js'",
    "lint:css": "stylelint 'resources/css/**/*.scss'",
    "format": "prettier --write 'resources/**/*.{js,css,json,blade.php}'",
    "lint": "npm run lint:js && npm run lint:css",
    "translate": "npm run translate:pot && npm run translate:update",
    "translate:pot": "wp i18n make-pot . ./resources/lang/sage.pot --include=\"theme.json,patterns,app,resources\"",
    "translate:update": "for file in ./resources/lang/*.po; do wp i18n update-po ./resources/lang/sage.pot $file; done",
    "translate:compile": "npm run translate:mo && npm run translate:js",
    "translate:js": "wp i18n make-json ./resources/lang --pretty-print",
    "translate:mo": "wp i18n make-mo ./resources/lang ./resources/lang"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "@roots/vite-plugin": "^1.0.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "laravel-vite-plugin": "^2.0.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.7.4",
    "purgecss-with-wordpress": "^7.0.2",
    "sass": "1.77.6",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-prettier": "^5.0.3",
    "vite": "^7.0.0"
  },
  "dependencies": {
    "@fancyapps/ui": "^6.1.7",
    "@fontsource-variable/eb-garamond": "^5.2.5",
    "@fontsource-variable/open-sans": "^5.2.7",
    "@popperjs/core": "^2.11.8",
    "@splidejs/splide": "^4.1.4",
    "bootstrap": "^5.3.8",
    "hamburgers": "^1.2.1",
    "headroom.js": "^0.12.0"
  }
}
