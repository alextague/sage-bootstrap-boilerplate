{
  "name": "roots/sage",
  "type": "wordpress-theme",
  "license": "MIT",
  "description": "WordPress starter theme with a modern development workflow",
  "homepage": "https://roots.io/sage/",
  "authors": [
    {
      "name": "Ben Word",
      "email": "ben@benword.com",
      "homepage": "https://github.com/retlehs"
    },
    {
      "name": "Scott Walkinshaw",
      "email": "scott.walkinshaw@gmail.com",
      "homepage": "https://github.com/swalkinshaw"
    },
    {
      "name": "QWp6t",
      "email": "hi@qwp6t.me",
      "homepage": "https://github.com/qwp6t"
    },
    {
      "name": "Brandon Nifong",
      "email": "brandon@tendency.me",
      "homepage": "https://github.com/log1x"
    }
  ],
  "keywords": [
    "wordpress"
  ],
  "support": {
    "issues": "https://github.com/roots/sage/issues",
    "forum": "https://discourse.roots.io/"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "exclude-from-classmap": [
      "vendor/laravel/framework/src/Illuminate/Foundation"
    ]
  },
  "repositories": [
    {
      "type":"composer",
      "url":"https://wpackagist.org",
      "only": [
        "wpackagist-plugin/*"
      ]
    },
    {
      "type": "composer",
      "url": "https://composer.deliciousbrains.com"
    },
    {
      "type": "composer",
      "url": "https://connect.advancedcustomfields.com"
    },
    {
      "type": "package",
      "package": {
        "name": "gravityforms/gravityforms",
        "version": "2.9.24",
        "type": "wordpress-plugin",
        "dist": {
          "type": "zip",
          "url": "https://www.gravityhelp.com/wp-content/plugins/gravitymanager/api.php?op=get_plugin&slug=gravityforms&key={%WP_PLUGIN_GF_KEY}"
        },
        "require": {
          "composer/installers": "^1.4",
          "gotoandplay/gravityforms-composer-installer": "^2.3"
        }
      }
    }
  ],
  "require": {
    "php": ">=8.4",
    "laravel/pint": "^1.20",
    "log1x/acf-composer": "^3.4.4",
    "log1x/sage-directives": "^2.0.6",
    "log1x/sage-svg": "^2.0.2",
    "owenvoke/blade-fontawesome": "^2.6.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0",
    "roots/acorn": "^5.0",
    "roots/acorn-post-types": "^1.0",
    "stoutlogic/acf-builder": "^1.12",
    "wp-cli/wp-cli": "^2.11"
  },
  "require-dev": {
    "gotoandplay/gravityforms-composer-installer": "^2.3",
    "gravityforms/gravityforms": "*",
    "wpengine/advanced-custom-fields-pro": "*",
    "deliciousbrains-plugin/wp-migrate-db-pro": "*",
    "deliciousbrains-plugin/wp-migrate-db-pro-cli": "*",
    "deliciousbrains-plugin/wp-migrate-db-pro-media-files": "*",
    "deliciousbrains-plugin/wp-migrate-db-pro-theme-plugin-files": "*",
    "wpackagist-plugin/classic-editor": "*",
    "wpackagist-plugin/mailchimp-for-wp": "*",
    "wpackagist-plugin/ewww-image-optimizer": "*",
    "wpackagist-plugin/google-analytics-dashboard-for-wp": "*",
    "wpackagist-plugin/redirection": "*",
    "wpackagist-plugin/safe-svg": "*",
    "wpackagist-plugin/simple-cloudflare-turnstile": "*",
    "wpackagist-plugin/wordpress-seo": "*"
  },
  "suggest": {
    "log1x/sage-directives": "A collection of useful Blade directives for WordPress and Sage (^1.0)."
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "composer/installers": true,
      "ffraenz/private-composer-installer": true,
      "gotoandplay/gravityforms-composer-installer": true,
      "kylekatarnls/update-helper": true,
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "post-autoload-dump": [
      "Roots\\Acorn\\ComposerScripts::postAutoloadDump"
    ],
    "test": [
      "@php vendor/bin/pest"
    ],
    "lint": [
      "@php vendor/bin/pint"
    ]
  },
  "extra": {
    "installer-paths": {
      "../../mu-plugins/{$name}/": ["type:wordpress-muplugin"],
      "../../plugins/{$name}/": ["type:wordpress-plugin"]
    }
  }
}
